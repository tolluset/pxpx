# Local gameplay server for a source checkout.
PIXEL_SERVER_URL=ws://127.0.0.1:1234

# Local Worker URL for login and repository access commands.
PIXEL_AUTH_SERVER_URL=ws://127.0.0.1:8787

# Optional room and player overrides.
# PIXEL_ROOM=pixel-game
# PIXEL_REPO=owner/repo
# PIXEL_NAME=alice

# Optional direct GitHub device-flow fallback when no Worker is available.
# PIXEL_GITHUB_CLIENT_ID=your_github_oauth_client_id
# GITHUB_CLIENT_ID=your_github_oauth_client_id

# Optional self-hosted Cloudflare deployment variables.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# GITHUB_SESSION_SECRET=
# ROOM_RESET_TOKEN=
